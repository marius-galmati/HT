---
interface Props { class?: string }
const { class: cls = 'w-12 h-12' } = Astro.props;
const uid = Math.random().toString(36).slice(2, 7);
---
<svg class={cls} viewBox="0 0 250 250" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <defs>
    <linearGradient id={`gb-${uid}`} x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#F0D584"/><stop offset="0.45" stop-color="#C79A2A"/>
      <stop offset="0.75" stop-color="#A87F1E"/><stop offset="1" stop-color="#7E5E12"/>
    </linearGradient>
    <linearGradient id={`gr-${uid}`} x1="0" y1="1" x2="1" y2="0">
      <stop offset="0" stop-color="#8F6B16"/><stop offset="0.35" stop-color="#C79A2A"/>
      <stop offset="0.65" stop-color="#F4DC8A"/><stop offset="1" stop-color="#C79A2A"/>
    </linearGradient>
  </defs>
  <g>
    <rect x="62" y="32" width="13" height="180" rx="2" fill={`url(#gb-${uid})`}/>
    <rect x="88" y="32" width="13" height="180" rx="2" fill={`url(#gb-${uid})`}/>
    <rect x="149" y="32" width="13" height="180" rx="2" fill={`url(#gb-${uid})`}/>
    <rect x="175" y="32" width="13" height="180" rx="2" fill={`url(#gb-${uid})`}/>
    <rect x="101" y="112" width="48" height="12" fill={`url(#gb-${uid})`}/>
  </g>
  <g fill="none" stroke-linecap="round">
    <path d="M 20 196 C 68 194, 100 168, 123 124 C 143 86, 175 58, 230 44" stroke="#0f0f12" stroke-width="23"/>
    <path d="M 34 212 C 84 209, 116 182, 137 138 C 156 99, 188 72, 238 58" stroke="#0f0f12" stroke-width="23"/>
    <path d="M 20 196 C 68 194, 100 168, 123 124 C 143 86, 175 58, 230 44" stroke={`url(#gr-${uid})`} stroke-width="12.5"/>
    <path d="M 34 212 C 84 209, 116 182, 137 138 C 156 99, 188 72, 238 58" stroke={`url(#gr-${uid})`} stroke-width="12.5"/>
  </g>
</svg>
